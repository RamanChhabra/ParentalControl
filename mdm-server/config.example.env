# Copy to .env, export, or use EnvironmentFile= with systemd.
#
# Cloudflare Tunnel: point cloudflared ingress to http://127.0.0.1:8443 (same
# host/port as MDM_LISTEN). TLS is at Cloudflare; leave MDM_TLS_* unset so the
# app serves HTTP only on loopback (not reachable except via the tunnel).
#
# Direct TLS / reverse proxy: listen on :8443 or behind nginx, set MDM_TLS_CERT
# and MDM_TLS_KEY to PEM paths (or terminate TLS in the proxy and use HTTP upstream).

MDM_LISTEN=127.0.0.1:8443
MDM_PUBLIC_BASE_URL=https://mdm.healthkart.com
# PEM/DER public CA for parental web filtering (served at /parental/filtering-ca.crt). Optional if certs/parental-filtering-ca.crt exists in cwd.
# MDM_PARENTAL_CA_CERT=/absolute/path/to/parental-filtering-ca.crt
# MDM_TLS_CERT=/path/to/fullchain.pem
# MDM_TLS_KEY=/path/to/privkey.pem
# From Apple MDM push certificate (com.apple.mgmt.External.*)
MDM_TOPIC=
# Optional: PEM for signing .mobileconfig (not implemented in scaffold)
# MDM_SIGN_CERT=
# MDM_SIGN_KEY=
