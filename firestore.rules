rules_version = '2';
// Parental Control - Firestore security rules.
// After editing: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    // Parent/child must be able to read device-scoped data. Any signed-in user can read
    // these collections (app restricts by device_id in queries). Tighter rules would
    // use get() to verify device ownership.

    match /users/{userId} {
      allow read, update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /devices/{deviceId} {
      allow read: if isSignedIn() && (
        resource.data.parent_id == request.auth.uid
        || resource.data.child_uid == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.parent_id == request.auth.uid;
    }

    match /pairing_codes/{code} {
      allow read, write: if isSignedIn();
    }

    match /app_usage/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /location_logs/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /rules/{docId} {
      allow read, write: if isSignedIn();
    }

    match /call_logs/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /sms_logs/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /app_install_requests/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
  }
}
